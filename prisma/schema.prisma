// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  category  String?
  forecasts Forecast[]
  sales     MonthlySales[]
  targets   ProductionTarget[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MonthlySales {
  id        String   @id @default(cuid())
  month     String   // e.g., "2024-03"
  quantity  Float
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([month, productId])
}

model Forecast {
  id        String   @id @default(cuid())
  month     String
  quantity  Float
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@unique([month, productId])
}

model ProductionTarget {
  id        String   @id @default(cuid())
  month     String
  target    Float
  actual    Float    @default(0)
  status    String   @default("in-progress") // in-progress, completed, warning
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([month, productId])
}

model SalesStrategy {
  id        String   @id @default(cuid())
  month     String
  title     String   @default("無題の施策")
  content   String   // AI generated advice
  priority  String   // HIGH, MEDIUM, INFO
  category  String   @default("AI_GENERATED") // AI_GENERATED, MANUAL, etc.
  status    String   @default("PENDING")      // PENDING, ACTIVE, COMPLETED
  createdAt DateTime @default(now())

  @@index([month])
  @@index([category])
}
