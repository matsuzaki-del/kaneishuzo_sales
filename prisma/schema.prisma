generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  sales     MonthlySales[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model Product {
  id        String             @id // 商品コード (文字列)
  name      String
  category  String?            // 製成名称 (純米酒、本醸造など)
  subCategory String?          // 製成コードがあれば
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sales     MonthlySales[]
  forecasts Forecast[]
  targets   ProductionTarget[]
  strategies SalesStrategy[]
}

model MonthlySales {
  id           Int      @id @default(autoincrement())
  month        String   // YYYY-MM
  quantity     Float    // 数量
  salesAmount  Float?   // 売上高
  unitPrice    Float?   // 単価
  
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id])
  
  productId    String
  product      Product  @relation(fields: [productId], references: [id])
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([month])
  @@index([customerId])
  @@index([productId])
}

model Forecast {
  id        String   @id @default(cuid())
  month     String
  quantity  Float
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([month, productId])
}

model ProductionTarget {
  id        String   @id @default(cuid())
  month     String
  target    Float
  actual    Float    @default(0)
  status    String   @default("in-progress")
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([month, productId])
}

model SalesStrategy {
  id        String   @id @default(cuid())
  month     String
  title     String   @default("無題の施策")
  content   String   // AI generated advice
  priority  String   // HIGH, MEDIUM, INFO
  category  String   @default("AI_GENERATED") // AI_GENERATED, MANUAL, etc.
  status    String   @default("PENDING")      // PENDING, ACTIVE, COMPLETED
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  createdAt DateTime @default(now())

  @@index([month])
  @@index([category])
  @@index([productId])
}
