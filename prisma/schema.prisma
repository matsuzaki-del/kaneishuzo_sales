generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id        String             @id @default(cuid())
  code      String             @unique
  name      String
  category  String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  forecasts Forecast[]
  sales     MonthlySales[]
  targets   ProductionTarget[]
}

model MonthlySales {
  id        String   @id @default(cuid())
  month     String
  quantity  Float
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([month, productId])
}

model Forecast {
  id        String   @id @default(cuid())
  month     String
  quantity  Float
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([month, productId])
}

model ProductionTarget {
  id        String   @id @default(cuid())
  month     String
  target    Float
  actual    Float    @default(0)
  status    String   @default("in-progress")
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([month, productId])
}

model SalesStrategy {
  id        String   @id @default(cuid())
  month     String
  content   String
  priority  String
  createdAt DateTime @default(now())
  category  String   @default("AI_GENERATED")
  status    String   @default("PENDING")
  title     String   @default("無題の施策")

  @@index([month])
  @@index([category])
}
